# Copy this file to .env and fill in your values.

# Port the API server runs on
PORT=4000

# Allow your frontend's origin (set to * while testing locally, lock it down in production)
CORS_ORIGIN=*

# ----- WhatsApp Cloud API (Meta) -----
# From https://developers.facebook.com/apps → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Any random string you choose — you'll enter the same value in the Meta
# webhook config screen. Used to verify the webhook belongs to you.
WHATSAPP_VERIFY_TOKEN=change-this-to-a-random-string

# Keyword contacts text to your WhatsApp Business number to opt in / out
OPT_IN_KEYWORD=JOIN
OPT_OUT_KEYWORD=STOP
