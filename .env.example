# Copy this file to .env and fill in your values.

# Port the API server runs on
PORT=4000

# ----- MongoDB Atlas (persistent storage — survives every redeploy) -----
# From MongoDB Atlas → your cluster → Connect → Drivers → copy the connection
# string and swap in the database username/password you created.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=maalwala

# Allow your frontend's origin (set to * while testing locally, lock it down in production)
CORS_ORIGIN=*

# ----- WhatsApp Cloud API (Meta) -----
# From https://developers.facebook.com/apps → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Any random string you choose — you'll enter the same value in the Meta
# webhook config screen. Used to verify the webhook belongs to you.
WHATSAPP_VERIFY_TOKEN=change-this-to-a-random-string

# Keyword contacts text to your WhatsApp Business number to opt in / out
OPT_IN_KEYWORD=JOIN
OPT_OUT_KEYWORD=STOP

# ----- Aditi Tracking (fleet GPS, pull API) -----
# Your real login for Aditi's platform — NOT the example from their PDF docs.
ADITI_USERNAME=
ADITI_PASSWORD=
# Exactly as registered with Aditi (used in the vehicle-lookup request).
ADITI_COMPANY_NAME=
# Only change these if Aditi gives you different values for your account.
ADITI_BASE_URL=http://13.126.244.90/webservice
ADITI_PROJECT_ID=37

# ----- Razorpay (collects payment from shippers) -----
# From your Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Settings → Webhooks → set the secret you choose here too
RAZORPAY_WEBHOOK_SECRET=

# ----- RazorpayX (pays transporters — separate KYC from regular Razorpay) -----
# Your RazorpayX current account number, from the RazorpayX dashboard
RAZORPAYX_ACCOUNT_NUMBER=
